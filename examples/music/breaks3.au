define kick(freq, amp, gate, attack, release, ffreq)
{
    out(0, lpf(sample("/Volumes/worx/samples/kit_kicks/tight/kick_layercake.wav", root : 60), ffreq) * env(gate, attack, 0, release) * amp * 0.5);
}

define snare(freq, amp, gate, attack, release, ffreq)
{
    out(0, lpf(sample("/Volumes/worx/samples/kit_dvoinoi11/BB15.wav", root : 60), ffreq) * env(gate, attack, 0, release) * amp);
}

define hat1(freq, amp, gate, attack, release, ffreq)
{
    out(0, lpf(sample("/Volumes/worx/samples/kit_dvoinoi11/NOI1.wav", root : 60), ffreq) * env(gate, attack, 0, release) * amp);
}

define hat2(freq, amp, gate, attack, release, ffreq)
{
    out(0, lpf(sample("/Volumes/worx/samples/kit_dvoinoi11/BB11.wav", root : 60), ffreq) * env(gate, attack, 0, release) * amp);
}

define hat3(freq, amp, gate, attack, release, ffreq)
{
    out(0, lpf(sample("/Volumes/worx/samples/kit_dvoinoi11/BB9.wav", root : 60), ffreq) * env(gate, attack, 0, release) * amp);
}

define hat4(freq, amp, gate, attack, release, ffreq)
{
    out(0, lpf(sample("/Volumes/worx/samples/kit_dvoinoi11/BB7.wav", root : 60), ffreq) * env(gate, attack, 0, release) * amp);
}

define wav1(freq, amp, gate, attack, release, ffreq, fq)
{
    let sig =
        bpf(
            var_saw(freq / 2, 0.2 * lfo_noise2(3.123), 1.0, 1),
            ffreq,
            0.5
        )
        * env(gate, 0.01, 0.0, release)
        * amp;
    out(0, sig * 0.15);
    out(1, sig * 0.15);
    out(4, sig * 0.5);
}

define bas1(freq, amp, gate, atk, sus, release, ffreq, fq, send1, send1_gain)
{
    let sig =
    bpf(
    square(freq / 2.001) * env(gate, atk * lfo_noise2(0.123), 0, release) * amp,
    ffreq,
    0.5
    );

    out(0, sig * 0.3);
    out(1, sig * 0.3);
    out(send1, sig * send1_gain);       // Wet signal to effect bus at specified gain
    out(send1+1, sig * send1_gain);       // Wet signal to effect bus at specified gain

}

// Effect 1: Short reverb (small room, subtle)
define reverb_short(bus) {
    let sig = in(bus, 2);
    out(0,  gverb(sig * 0.15, 51, 11, 0.95));
    out(1,  gverb(sig * 0.15, 61, 51, 0.95));
}

// Effect 2: Long reverb (cathedral, huge space)
define reverb_long(bus) {
    let sig = in(bus, 2);
    out(0,  gverb(sig * 0.2, 130, 9110, 0.95) * 0.5);
    out(1,  gverb(sig * 0.2, 142, 9115, 0.95) * 0.5);
}

synth("reverb_short", bus: 2);
synth("reverb_long", bus: 4);



