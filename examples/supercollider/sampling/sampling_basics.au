        let l = nil;
        loop {
            bli += 1;
            wait(3);
            let a = rand(0.001, 0.55);   // random attack
            print("bli");
            print(bli % 3);

            if (l != nil) { free(l); }
            l = synth(
                "bassline_2",
                freq : tune(array_rand(sequences["bassline_1"])),
                amp : 0.139,
                atk: 0.01,
                sus: 1,
                rel: 2,
                filter_freq : 1420
            );
            wait(2);
        }
    }

