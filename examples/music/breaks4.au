define wav1(freq, loop_startn, amp, gate, attack, release, ffreq, send1, pann)
{
    let sig = lpf(sample("/Volumes/worx/samples/kit_synths_wavetable/wave01.wav", loop: 1, start : loop_startn, root : 60), ffreq / 2) * env(gate, attack, 0, release) * amp * 0.35;
    out(6, pan(pann, sig * 0.15));
    out(send1, pan(pann, sig * 0.15));
}

define wav2(freq, loop_startn, amp, gate, attack, release, ffreq, send1, pann)
{
    let sig = lpf(sample("/Volumes/worx/samples/kit_synths_wavetable/wave02.wav", loop: 1, start : loop_startn, root : 60), ffreq / 2) * env(gate, attack, 0, release) * amp;
    out(6, pan(pann, sig * 0.15));
    out(send1, pan(pann, sig * 0.15));
}

define wav3(freq, loop_startn, amp, gate, attack, release, ffreq, send1, pann)
{
    let sig = lpf(sample("/Volumes/worx/samples/kit_synths_wavetable/wave04.wav", loop: 1, start : loop_startn, root : 60), ffreq / 2) * env(gate, attack, 0, release) * amp;
    out(6, pan(pann, sig * 0.15));
    out(send1, pan(pann, sig * 0.15));
}

define wav4(freq, amp, gate, attack, release, ffreq, fq, send1, pann)
{
    let sig =
        bpf(
            var_saw(freq / 2.001, 0.2 * lfo_noise2(3.123), 1.0, 1),
            ffreq,
            0.5
        )
        * env(gate, 0.01, 0.0, release)
        * amp * 0.45;
    out(6, pan(pann, sig * 0.5));
    out(send1, pan(pann, sig * 0.5));
}


// Effect 1: Short reverb (small room, subtle)
define reverb_short(bus) {
    let sig = in(bus, 2);
    out(6,  gverb(sig * 0.15, 51, 11, 0.95));
    out(7,  gverb(sig * 0.15, 61, 51, 0.95));
}

// Effect 2: Long reverb (cathedral, huge space)
define reverb_long(bus) {
    let sig = in(bus, 2);
    out(6,  gverb(sig, 330, 9110, 0.65, 0.5, 70) * 0.2);
    out(7,  gverb(sig, 342, 9115, 0.65, 0.5, 70) * 0.25);
    out(0,  gverb(sig, 342, 9115, 0.65, 0.5, 70) * 0.25);
}

define some_delay(in_bus, decay) {
    let input = in(in_bus, 2);
    let delrd = local_in(4);
    let output = input[0] + input[1] + (delrd[0] + delrd[1]) * 0.4;
    let delayed0 = delay_c(output, 0.10, 0.3);
    let delayed2 = delay_c(output, 0.11, 0.4);
    let delayed1 = delay_c(output, 0.12, 0.5);
    let delayed3 = delay_c(output, 0.13, 0.6);
    local_out(array(delayed0, delayed1, delayed2, delayed3));
    out(6, output * 0.45);
    out(7, output * 0.45);

}

// FDN Reverb - reads from input bus, outputs to main
define fdn_reverb(in_bus, decay, freq) {
    // Read input from bus (stereo)
    let input = in(in_bus, 2);

    // Read our 4-channel delayed signals back from the feedback loop
    let delrd = local_in(4);

    // Mix input with feedback
    let output = input + delrd[0] + delrd[1];

    // Cross-fertilise the four delay lines with each other (Hadamard-like matrix):
    // This creates the diffusion that makes it sound like reverb
    let sum_lr = output[0] + output[1];
    let diff_lr = output[0] - output[1];
    let sum_fb = delrd[2] + delrd[3];
    let diff_fb = delrd[2] - delrd[3];

    // Mix and attenuate in one step (decay values control reverb time)
    let sig0 = (sum_lr + sum_fb) * (0.4 * decay * lfo_noise2(3.123));
    let sig1 = (diff_lr + diff_fb) * (0.3 * decay);
    let sig2 = (sum_lr - sum_fb) * (0.2 * decay * lfo_noise2(4.123));
    let sig3 = (diff_lr - diff_fb) * (0.1 * decay);


    // Prime number delay times in seconds for dense, non-metallic reverb
    // 101ms, 143ms, 165ms, 177ms
    let time0 = 0.50;
    let time1 = 0.160;
    let time2 = 0.270;
    let time3 = 0.380;

    // Apply delays - DelayC is cubic interpolation delay
    let delayed0 = delay_c(sig0, 0.90, time0);
    let delayed1 = freq_shift(delay_c(sig1, 0.100, time1), freq / 2 * lfo_noise2(12.123), 0);
    let delayed2 = delay_c(sig2, 0.210, time2);
    let delayed3 = delay_c(sig3, 0.320, time3);

    // Feed back into the delay network
    local_out(array(delayed0, delayed1, delayed2, delayed3));

    // Output stereo to main
    out(6, output * 0.65);
}

define comp(bus) {
    let sig1 = in(bus, 2);
    let sig2 = in(bus, 3);
    let compsig = compander(sig1, sig2, 0.3, 1, 0.5, 0.01, 0.3);
    out(0, compsig);
    // out(1, compsig);

    // Compander.ar(z, z,
    //     thresh: MouseX.kr(0.01, 1),
    //     slopeBelow: 1,
    //     slopeAbove: 0.5,
    //     clampTime:  0.01,
    //     relaxTime:  0.01
    // )
}

