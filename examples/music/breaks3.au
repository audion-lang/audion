fn tune(n) {
    return mtof(n, "./2-harmonic-minor-et.scl");
}

fn arpy(times, next) {
    print("arpy");
    thread arpy1 {
        for(i = 0; i < times; i+=1) {
            synth(next[0], freq: tune(next.note), amp: next.a(), release: next.r(), ffreq: 5500);
            wait(1/8);
        }
    }
}

fn arpy_rand_time(times, next) {
    print("arpy_rand_time");
    thread arpy1 {
        for(i = 0; i < times; i+=1) {
            synth(next[0], freq: tune(next.note), amp: next.a(), release: next.r(), ffreq: 5500);
            wait(array_rand([1/16, 1/4]));
        }
    }
}

fn arpy_rand_mel(times, next) {
    thread arpy1 {
        mel = array_mel_random_walk(next.note, next.note - 12, next.note, 7, 32);
        for(i = 0; i < times; i+=1) {
            synth(next[0], freq: tune(array_next(mel)), amp: next.a() * 0.6, release: next.r(), ffreq: rand(600, 5000));
            wait(array_rand([1, 2, 4, 6, 8]));
        }
    }
}

fn main()
{

bass_break_train = breaks_train = [];

thread main_beat {
    seed("yo-man");
    breaks_seq = array_seq_euclidean(7, 16);
    print(breaks_seq);
    loop {
        next = array_next(main_beat);
        next_break = array_next(breaks_seq);
        if (next_break && rand() > 0.95 && next[0] != "kick" && next[0] != "snare") {
            next = array_rand(main_beat);
        }
        synth(next[0], freq: tune(next.note), amp: next.a() * 0.5, release: next.r(), ffreq: rand(3000, 4500), fq: rand(0.07, 0.09));
        if (next[0] != "kick" && next[0] != "snare") {
            arp_option = rand();
            if (next_break && arp_option > 0.95) {
                print("arpy1!");
                arp_options = ["arpy_rand_time", "arpy"];
                array_rand(arp_options)(array_rand(array_mel_random_walk(4, 0, 9, 4, 16)), next);
                wait(next[1]);
                array_push(breaks_train, next[1]);
            }
            if (next_break && arp_option > 0.85 && arp_option < 0.90) {
                print("arpy2!");
                arpy(16, ["nothing",1/4, "a" => fn(){return 0;}, "r" => fn(){return 0;}, "note" => 52]);
                wait(next[1]);
                array_push(breaks_train, next[1]);
            }
            wait(next[1]);
        } else {
            wait(next[1]);
        }
    }
}



thread main_mel {
    seed("yo");
    breaks_seq = array_seq_euclidean(7, 16);
    wait(1/4);
    loop {
        next = array_next(main_mel);
        break_seq = array_next(breaks_seq);
        if (break_seq == 0) {
            // synth(next[0], freq: tune(next.note - 12), amp: next.a() * 2, release: next.r() * 2, ffreq: rand(200, 1500), fq: rand(0.07, 0.9));
        }
        if (count(breaks_train)) {
            arpy_rand_mel(array_rand([64, 32, 16, 12, 7, 9, 3, 4, 8]), next);
            // synth(next[0], freq: tune(next.note - 5), amp: next.a(), release: next.r() * 12, ffreq: 2500);
            for (a=0; a<count(breaks_train); a+=1) {
                synth(next[0], freq: tune(next.note - 7), amp: next.a(), release: next.r() * 12, ffreq: 2500);
                wait(breaks_train[a]);
            }
            bass_break_train = breaks_train; // pass it on!
            breaks_train = [];
        }
        wait(next[1]);
    }
}


thread bas_mel {
    seed("yobas");
    // bassline = array_mel_random_walk(44, 40, 60, 12, 16);
    bassline = [50, 50, 54, 54, 66, 55, 54, 62, 51, 59, 55, 57, 55];
    wait(1/4);
    loop {
        synth("bas1", freq: tune(array_next(bassline)), amp: 0.32852, release: 1.5, ffreq: rand(200, 500), fq: rand(0.07, 0.9));
        wait(1/2);
        if (count(bass_break_train)) {
            for (a=0; a<count(bass_break_train); a+=1) {
                wait(bass_break_train[a]);
            }
            bass_break_train = [];
        }
    }
}


}



