seed("what you want it to be");
let tune_walk = array_mel_random_walk(0, -6, 6, 7, 64);
print(tune_walk);
let next_tune_walk = 0;

fn tune(n) {
    // return mtof(n, "./2-harmonic-minor-et.scl");
    // return mtof(n, "../scala_scales/7-mixolydian-et.scl");
    // return mtof(n, "/Volumes/worx/soft/audion/examples/ignore_scala_scales/starling.scl");
    // scale_file = "../scala_scales/4-dorian-et.scl";
    scale_file = "../scala_scales/7-mixolydian-et.scl";
    return mtof(math_clamp((n + next_tune_walk) / 1.2, 54, 75), scale_file);
}

fn tune2(n) {
    // return mtof(n, "./2-harmonic-minor-et.scl");
    // return mtof(n, "../scala_scales/7-mixolydian-et.scl");
    // return mtof(n, "/Volumes/worx/soft/audion/examples/ignore_scala_scales/starling.scl");
    // scale_file = "../scala_scales/4-dorian-et.scl";
    scale_file = "../scala_scales/7-mixolydian-et.scl";
    return mtof(n / 1.2, scale_file);
}


fn main()
{


    thread tune_walker {
        loop {
            next_tune_walk = math_round(array_next(tune_walk));
            print("next_tune_walk", next_tune_walk);
            wait(16);
        }
    }


    main_beat_short_wait = 1;
    main_beat_long_wait = 1;

    thread main_beat_waits_walker {
        seed("may you be at peace");
        divisors = [11, 12, 13, 2, 5];
        multipliers = [1, 0.8, 1];
        main_beat_wait_sequencer = [2, 3, 2, 4];
        loop {
            wait(array_next(main_beat_wait_sequencer));
            divisor = array_next(divisors);
            multiplier = array_next(multipliers);
            main_beat_short_wait = (1/divisor)*multiplier;
            print("main_beat_short_wait", main_beat_short_wait);
            main_beat_long_wait = (multiplier/divisor)*multiplier;
            print("main_beat_long_wait", main_beat_long_wait);
        }
    }

    thread main_beat {
        seed("yo-julene-mama");
        breaks_seq = array_seq_euclidean(5, 24);
        root_notes = array_mel_random_walk(65, 50, 82, 15, 64);
        filter_walk = array_mel_random_walk(1200, 870, 4500, 35, 128);
        amp_walk = array_mel_random_walk(0.1, 0.01, 2.0, 0.25, 254);
        loop {
            print("array_next(amp_walk)", array_next(amp_walk));
            next = array_next(main_beat);
            next_break = array_next(breaks_seq);
            send1_to = array_rand([0, 10, 8, 2, 8, 2, 2, 4, 4, 4, 4, ]);
            synth(
                next[0],
                loop_startn: rand(0.01 * 4000, 5.99 * 4000),
                freq: tune(array_next(root_notes)),
                attack: array_rand([0.2, 0.9, 0]),
                amp: array_next(amp_walk),
                release: rand(next.r[0], next.r[1]),
                ffreq: array_next(filter_walk),
                fq: rand(0.07, 0.09),
                send1: send1_to,
                pann: rand(-1.0, 1.0)
            );
            if (next_break == 0) {
                wait(main_beat_short_wait);
            } else {
                wait(main_beat_long_wait);
            }
        }
    }



    thread second_mel {
        seed("yo-aasss");
        breaks_seq = array_seq_euclidean(7, 16);
        root_notes = array_mel_random_walk(65, 50, 82, 15, 16);
        filter_walk = array_mel_random_walk(200, 200, 4500, 50, 128);

        loop {
            next = array_next(backup_beat);
            next_break = array_next(breaks_seq);
            send1_to = array_rand([0, 2, 8, 2, 2, 8, 8, 4, 4, 8, 8, 8, 8, 0, 0, 4, 4, 2]);
            next_note = array_next(root_notes);
            synth(
                next[0],
                loop_startn: rand(0.01 * 4000, 5.99 * 4000),
                freq: tune2(next_note),
                amp: rand(next.a[0], next.a[1]),
                release: rand(next.r[0] * 2, next.r[1] * 2),
                ffreq: array_next(filter_walk),
                fq: rand(0.07, 0.09),
                send1: send1_to,
                pann: rand(-1.0, 1.0)
            );
            set(reverb, decay: rand(0.0001, 1.0), freq: tune(next_note) + rand(1,25));
            if (next_break == 0) {
                wait(1/2);
            } else {
                if (rand() > 0.8) {
                    wait(3);
                }
                wait(1);
            }
        }
    }


}








